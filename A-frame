<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Café Eden — Sunlit Terrace</title>

  <!-- A-Frame -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/aframe/1.4.2/aframe.min.js"></script>

  <style>
    /* ── Reset ── */
    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'Segoe UI', sans-serif;
      background: #111;
      overflow: hidden;
    }

    /* ── Title badge (top-left, name only – no subtitle) ── */
    #title-card {
      position: fixed;
      top: 16px;
      left: 18px;
      background: rgba(0, 0, 0, 0.50);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      color: #fff;
      padding: 10px 20px;
      border-radius: 14px;
      z-index: 999;
      pointer-events: none;
      border: 1px solid rgba(255,255,255,0.15);
    }
    #title-card h1 {
      font-size: 16px;
      font-weight: 600;
      letter-spacing: 0.6px;
      white-space: nowrap;
    }

    /* ── Navigation hint (bottom-centre) ── */
    #hud {
      position: fixed;
      bottom: 18px;
      left: 50%;
      transform: translateX(-50%);
      background: rgba(0, 0, 0, 0.50);
      backdrop-filter: blur(8px);
      -webkit-backdrop-filter: blur(8px);
      color: #fff;
      font-size: 12.5px;
      padding: 7px 20px;
      border-radius: 30px;
      pointer-events: none;
      letter-spacing: 0.4px;
      z-index: 999;
      white-space: nowrap;
      border: 1px solid rgba(255,255,255,0.12);
    }

    /* ── Scene fills viewport ── */
    a-scene { width: 100vw; height: 100vh; }
  </style>
</head>
<body>

  <!-- ── Overlays ── -->
  <div id="title-card">
    <h1>🌿 Café Eden — Sunlit Terrace</h1>
  </div>
  <div id="hud">🖱 Drag to look &nbsp;·&nbsp; W A S D to walk</div>


  <!-- ══════════════════════════════════════════════════════
       A-FRAME SCENE
  ══════════════════════════════════════════════════════ -->
  <a-scene background="color:#87CEEB" renderer="antialias:true">

    <!-- ── SKY ── -->
    <a-sky color="#87CEEB"></a-sky>

    <!-- ── SUN ── -->
    <a-sphere position="8 13 -20" radius="1.6"
      color="#FFD700"
      material="emissive:#FFD700;emissiveIntensity:0.6">
    </a-sphere>

    <!-- ── GROUND (grass) ── -->
    <a-plane position="0 0 0" rotation="-90 0 0"
      width="40" height="40" color="#5A8F3C" roughness="1">
    </a-plane>
    <!-- Colour variation patches -->
    <a-plane position=" 6 0.01 -4" rotation="-90 0 0" width="9"  height="7"  color="#4E7A34"></a-plane>
    <a-plane position="-7 0.01  2" rotation="-90 0 0" width="7"  height="9"  color="#6BA040"></a-plane>
    <a-plane position=" 0 0.01  5" rotation="-90 0 0" width="12" height="5"  color="#62983E"></a-plane>


    <!-- ════════════════════════════════
         ROUND PATIO TABLE
         Table-top surface  y = 1.04
    ════════════════════════════════ -->

    <!-- Surface -->
    <a-cylinder position="0 1.0 -3"
      radius="1.1" height="0.08"
      color="#8B6914" roughness="0.8">
    </a-cylinder>

    <!-- Decorative edge rim -->
    <a-torus position="0 1.045 -3"
      radius="1.06" radius-tubular="0.032"
      color="#6B4F0A" rotation="90 0 0">
    </a-torus>

    <!-- Centre pedestal -->
    <a-cylinder position="0 0.5 -3"
      radius="0.065" height="1.0" color="#6B4F0A">
    </a-cylinder>

    <!-- Cross base -->
    <a-box position="0 0.04 -3" width="1.5" height="0.07" depth="0.13" color="#6B4F0A"></a-box>
    <a-box position="0 0.04 -3" width="0.13" height="0.07" depth="1.5"  color="#6B4F0A"></a-box>


    <!-- ════════════════════════════════
         2 WOODEN CHAIRS
         LEFT  (-1.6, 0, -3)  rotated 90° facing table
         RIGHT ( 1.6, 0, -3)  rotated -90° facing table
    ════════════════════════════════ -->

    <!-- CHAIR LEFT -->
    <a-entity position="-1.65 0 -3" rotation="0 90 0">
      <!-- Seat -->
      <a-box position="0 0.55 0"
        width="0.68" height="0.08" depth="0.68" color="#A0522D">
      </a-box>
      <!-- Seat cushion -->
      <a-box position="0 0.60 0"
        width="0.60" height="0.06" depth="0.60" color="#C47A3A">
      </a-box>
      <!-- Front-left leg -->
      <a-box position="-0.28 0.27  0"    width="0.07" height="0.55" depth="0.07" color="#8B4513"></a-box>
      <!-- Front-right leg -->
      <a-box position=" 0.28 0.27  0"    width="0.07" height="0.55" depth="0.07" color="#8B4513"></a-box>
      <!-- Back-left leg -->
      <a-box position="-0.28 0.27  0.30" width="0.07" height="0.55" depth="0.07" color="#8B4513"></a-box>
      <!-- Back-right leg -->
      <a-box position=" 0.28 0.27  0.30" width="0.07" height="0.55" depth="0.07" color="#8B4513"></a-box>
      <!-- Backrest panel -->
      <a-box position="0 0.90 -0.30"
        width="0.68" height="0.58" depth="0.06" color="#A0522D">
      </a-box>
      <!-- Backrest top rail -->
      <a-box position="0 1.19 -0.30"
        width="0.68" height="0.06" depth="0.08" color="#8B4513">
      </a-box>
    </a-entity>

    <!-- CHAIR RIGHT -->
    <a-entity position="1.65 0 -3" rotation="0 -90 0">
      <!-- Seat -->
      <a-box position="0 0.55 0"
        width="0.68" height="0.08" depth="0.68" color="#A0522D">
      </a-box>
      <!-- Seat cushion -->
      <a-box position="0 0.60 0"
        width="0.60" height="0.06" depth="0.60" color="#C47A3A">
      </a-box>
      <!-- Legs -->
      <a-box position="-0.28 0.27  0"    width="0.07" height="0.55" depth="0.07" color="#8B4513"></a-box>
      <a-box position=" 0.28 0.27  0"    width="0.07" height="0.55" depth="0.07" color="#8B4513"></a-box>
      <a-box position="-0.28 0.27  0.30" width="0.07" height="0.55" depth="0.07" color="#8B4513"></a-box>
      <a-box position=" 0.28 0.27  0.30" width="0.07" height="0.55" depth="0.07" color="#8B4513"></a-box>
      <!-- Backrest panel -->
      <a-box position="0 0.90 -0.30"
        width="0.68" height="0.58" depth="0.06" color="#A0522D">
      </a-box>
      <!-- Backrest top rail -->
      <a-box position="0 1.19 -0.30"
        width="0.68" height="0.06" depth="0.08" color="#8B4513">
      </a-box>
    </a-entity>


    <!-- ════════════════════════════════
         TABLE ITEMS
         All built with ABSOLUTE positions
         (no nested entity offsets)
         Table top surface = y 1.045
    ════════════════════════════════ -->

    <!-- ┌────────────────────────────────┐
         │  MILO TIN  (back-left)         │
         │  Green tin, tall               │
         └────────────────────────────────┘ -->
    <!-- Body -->
    <a-cylinder position="-0.42 1.26 -2.55"
      radius="0.115" height="0.43"
      color="#1A5E1A" roughness="0.4">
    </a-cylinder>
    <!-- Top label band -->
    <a-cylinder position="-0.42 1.33 -2.55"
      radius="0.122" height="0.15"
      color="#2DB82D" roughness="0.3">
    </a-cylinder>
    <!-- White text strip on label -->
    <a-cylinder position="-0.42 1.33 -2.55"
      radius="0.123" height="0.07"
      color="#e8ffe8" roughness="0.3">
    </a-cylinder>
    <!-- Lid -->
    <a-cylinder position="-0.42 1.495 -2.55"
      radius="0.122" height="0.06"
      color="#A0A000">
    </a-cylinder>
    <!-- Lid top cap -->
    <a-cylinder position="-0.42 1.532 -2.55"
      radius="0.10" height="0.02"
      color="#808000">
    </a-cylinder>

    <!-- ┌────────────────────────────────┐
         │  MILK TIN  (back-right)        │
         │  White/silver tin              │
         └────────────────────────────────┘ -->
    <!-- Body -->
    <a-cylinder position="0.42 1.22 -2.55"
      radius="0.115" height="0.36"
      color="#EEEEEE" roughness="0.3">
    </a-cylinder>
    <!-- Blue label band -->
    <a-cylinder position="0.42 1.24 -2.55"
      radius="0.122" height="0.14"
      color="#2255CC" roughness="0.3">
    </a-cylinder>
    <!-- White strip on label -->
    <a-cylinder position="0.42 1.24 -2.55"
      radius="0.123" height="0.06"
      color="#cce0ff" roughness="0.3">
    </a-cylinder>
    <!-- Lid -->
    <a-cylinder position="0.42 1.455 -2.55"
      radius="0.122" height="0.055"
      color="#BBBBBB">
    </a-cylinder>
    <!-- Lid cap -->
    <a-cylinder position="0.42 1.488 -2.55"
      radius="0.10" height="0.02"
      color="#999999">
    </a-cylinder>

    <!-- ┌────────────────────────────────┐
         │  SUGAR BOWL  (centre)          │
         └────────────────────────────────┘ -->
    <!-- Base plate -->
    <a-cylinder position="0 1.056 -3.0"
      radius="0.175" height="0.03"
      color="#E0D9C5">
    </a-cylinder>
    <!-- Bowl lower body -->
    <a-sphere position="0 1.13 -3.0"
      radius="0.135"
      color="#FFF8E7"
      scale="1 0.8 1">
    </a-sphere>
    <!-- Lid dome -->
    <a-sphere position="0 1.21 -3.0"
      radius="0.12"
      color="#F2ECD8"
      scale="1 0.6 1">
    </a-sphere>
    <!-- Lid knob stem -->
    <a-cylinder position="0 1.285 -3.0"
      radius="0.018" height="0.055"
      color="#C4AA80">
    </a-cylinder>
    <!-- Lid knob ball -->
    <a-sphere position="0 1.32 -3.0"
      radius="0.028"
      color="#D4BA90">
    </a-sphere>

    <!-- ┌────────────────────────────────┐
         │  CUP 1 + SAUCER  (front-left)  │
         └────────────────────────────────┘ -->
    <!-- Saucer -->
    <a-cylinder position="-0.42 1.056 -3.45"
      radius="0.195" height="0.028"
      color="#D5CEBC">
    </a-cylinder>
    <!-- Saucer rim ring -->
    <a-torus position="-0.42 1.072 -3.45"
      radius="0.175" radius-tubular="0.012"
      color="#C4BDA8" rotation="90 0 0">
    </a-torus>
    <!-- Cup base foot -->
    <a-cylinder position="-0.42 1.088 -3.45"
      radius="0.08" height="0.025"
      color="#EDE6D0">
    </a-cylinder>
    <!-- Cup body (tapered: slightly wider at top) -->
    <a-cylinder position="-0.42 1.185 -3.45"
      radius="0.10" height="0.20"
      color="#FFFAF0" roughness="0.15">
    </a-cylinder>
    <!-- Cup rim -->
    <a-torus position="-0.42 1.288 -3.45"
      radius="0.10" radius-tubular="0.010"
      color="#D8D0BB" rotation="90 0 0">
    </a-torus>
    <!-- Cup handle (box stub) -->
    <a-box position="-0.265 1.19 -3.45"
      width="0.05" height="0.09" depth="0.025"
      color="#EDE6D0">
    </a-box>

    <!-- ┌────────────────────────────────┐
         │  CUP 2 + SAUCER  (front-right) │
         └────────────────────────────────┘ -->
    <!-- Saucer -->
    <a-cylinder position="0.42 1.056 -3.45"
      radius="0.195" height="0.028"
      color="#D5CEBC">
    </a-cylinder>
    <!-- Saucer rim ring -->
    <a-torus position="0.42 1.072 -3.45"
      radius="0.175" radius-tubular="0.012"
      color="#C4BDA8" rotation="90 0 0">
    </a-torus>
    <!-- Cup base foot -->
    <a-cylinder position="0.42 1.088 -3.45"
      radius="0.08" height="0.025"
      color="#EDE6D0">
    </a-cylinder>
    <!-- Cup body -->
    <a-cylinder position="0.42 1.185 -3.45"
      radius="0.10" height="0.20"
      color="#FFFAF0" roughness="0.15">
    </a-cylinder>
    <!-- Cup rim -->
    <a-torus position="0.42 1.288 -3.45"
      radius="0.10" radius-tubular="0.010"
      color="#D8D0BB" rotation="90 0 0">
    </a-torus>
    <!-- Cup handle -->
    <a-box position="0.575 1.19 -3.45"
      width="0.05" height="0.09" depth="0.025"
      color="#EDE6D0">
    </a-box>

    <!-- ┌────────────────────────────────┐
         │  SPOON 1  (left of Cup 1)      │
         └────────────────────────────────┘ -->
    <!-- Handle -->
    <a-cylinder position="-0.66 1.06 -3.45"
      radius="0.014" height="0.26"
      color="#D0D0D0" rotation="0 0 12">
    </a-cylinder>
    <!-- Spoon head/bowl -->
    <a-sphere position="-0.63 1.17 -3.45"
      radius="0.030"
      color="#E0E0E0"
      scale="1 0.55 1.3">
    </a-sphere>

    <!-- ┌────────────────────────────────┐
         │  SPOON 2  (right of Cup 2)     │
         └────────────────────────────────┘ -->
    <!-- Handle -->
    <a-cylinder position="0.66 1.06 -3.45"
      radius="0.014" height="0.26"
      color="#D0D0D0" rotation="0 0 -12">
    </a-cylinder>
    <!-- Spoon head/bowl -->
    <a-sphere position="0.63 1.17 -3.45"
      radius="0.030"
      color="#E0E0E0"
      scale="1 0.55 1.3">
    </a-sphere>


    <!-- ════════════════════════════════
         SUMMER STRAW HAT
         (lying on the grass, left side)
    ════════════════════════════════ -->
    <a-entity position="-2.9 0 -2.4" rotation="0 20 0">
      <!-- Wide straw brim -->
      <a-cylinder radius="0.70" height="0.065"
        color="#D2A679" roughness="0.9">
      </a-cylinder>
      <!-- Crown body -->
      <a-cylinder radius="0.33" height="0.40"
        color="#C49055" roughness="0.9"
        position="0 0.23 0">
      </a-cylinder>
      <!-- Crown top cap -->
      <a-cylinder radius="0.33" height="0.045"
        color="#BA8045"
        position="0 0.43 0">
      </a-cylinder>
      <!-- Hat band (torus) -->
      <a-torus radius="0.33" radius-tubular="0.032"
        color="#8B4513" rotation="90 0 0"
        position="0 0.16 0">
      </a-torus>
      <!-- Bow – left loop -->
      <a-box position="0.31 0.16  0.10"
        width="0.14" height="0.055" depth="0.045"
        color="#CC3333" rotation="0 28 0">
      </a-box>
      <!-- Bow – right tail -->
      <a-box position="0.33 0.16  0.05"
        width="0.07" height="0.050" depth="0.040"
        color="#AA1111" rotation="0 28 0">
      </a-box>
    </a-entity>


    <!-- ════════════════════════════════
         RED PATIO UMBRELLA (above table)
    ════════════════════════════════ -->
    <!-- Pole -->
    <a-cylinder position="0 1.5 -3"
      radius="0.045" height="2.6" color="#999999">
    </a-cylinder>
    <!-- Outer canopy -->
    <a-cone position="0 2.85 -3"
      radius-bottom="2.3" radius-top="0.08" height="0.75"
      color="#E84040" roughness="0.7">
    </a-cone>
    <!-- Inner shadow stripe -->
    <a-cone position="0 2.82 -3"
      radius-bottom="2.2" radius-top="0.05" height="0.68"
      color="#BB1A1A" roughness="0.7" open-ended="true">
    </a-cone>
    <!-- Finial tip -->
    <a-cone position="0 3.23 -3"
      radius-bottom="0.08" radius-top="0.01" height="0.18"
      color="#777777">
    </a-cone>


    <!-- ════════════════════════════════
         FLOWER POT  (right of table)
    ════════════════════════════════ -->
    <a-entity position="2.6 0 -2.2">
      <!-- Pot body -->
      <a-cylinder radius="0.24" height="0.40"
        color="#C06020" roughness="0.8">
      </a-cylinder>
      <!-- Pot rim -->
      <a-torus radius="0.24" radius-tubular="0.025"
        color="#A05010" rotation="90 0 0"
        position="0 0.20 0">
      </a-torus>
      <!-- Soil surface -->
      <a-cylinder radius="0.22" height="0.04"
        color="#4A3020" position="0 0.20 0">
      </a-cylinder>
      <!-- Stem -->
      <a-cylinder radius="0.022" height="0.60"
        color="#2D6E1E" position="0 0.50 0">
      </a-cylinder>
      <!-- Centre blossom -->
      <a-sphere radius="0.16"
        color="#FFD700" roughness="0.4"
        position="0 0.82 0">
      </a-sphere>
      <!-- Pink petals -->
      <a-sphere radius="0.09" color="#FF5599" position=" 0.20 0.78  0.00"></a-sphere>
      <a-sphere radius="0.09" color="#FF5599" position="-0.20 0.78  0.00"></a-sphere>
      <a-sphere radius="0.09" color="#FF5599" position=" 0.00 0.78  0.20"></a-sphere>
      <a-sphere radius="0.09" color="#FF5599" position=" 0.00 0.78 -0.20"></a-sphere>
      <a-sphere radius="0.07" color="#FF88BB" position=" 0.14 0.79  0.14"></a-sphere>
      <a-sphere radius="0.07" color="#FF88BB" position="-0.14 0.79  0.14"></a-sphere>
      <a-sphere radius="0.07" color="#FF88BB" position=" 0.14 0.79 -0.14"></a-sphere>
      <a-sphere radius="0.07" color="#FF88BB" position="-0.14 0.79 -0.14"></a-sphere>
      <!-- Leaves -->
      <a-box position=" 0.14 0.42 0"
        width="0.17" height="0.04" depth="0.09"
        color="#2D8B1E" rotation="0 0  32">
      </a-box>
      <a-box position="-0.14 0.34 0"
        width="0.17" height="0.04" depth="0.09"
        color="#2D8B1E" rotation="0 0 -32">
      </a-box>
    </a-entity>


    <!-- ════════════════════════════════
         BACKGROUND TREES
    ════════════════════════════════ -->

    <!-- Tree 1 – back-left, conifer style -->
    <a-entity position="-5.5 0 -8">
      <a-cylinder radius="0.20" height="2.0" color="#6B4226"></a-cylinder>
      <a-cone radius-bottom="1.3" radius-top="0.05" height="2.4"
        position="0 2.6 0" color="#2E7D32">
      </a-cone>
      <a-cone radius-bottom="1.05" radius-top="0.05" height="2.0"
        position="0 3.6 0" color="#388E3C">
      </a-cone>
    </a-entity>

    <!-- Tree 2 – back-right, conifer style -->
    <a-entity position="6 0 -9">
      <a-cylinder radius="0.20" height="2.0" color="#6B4226"></a-cylinder>
      <a-cone radius-bottom="1.4" radius-top="0.05" height="2.6"
        position="0 2.7 0" color="#1B5E20">
      </a-cone>
      <a-cone radius-bottom="1.1" radius-top="0.05" height="2.0"
        position="0 3.8 0" color="#2E7D32">
      </a-cone>
    </a-entity>

    <!-- Tree 3 – mid-right, round canopy -->
    <a-entity position="7.5 0 -5.5">
      <a-cylinder radius="0.16" height="1.7" color="#5C3317"></a-cylinder>
      <a-sphere radius="1.1" color="#2E7B1E" position="0 2.5 0"></a-sphere>
    </a-entity>

    <!-- Tree 4 – far left -->
    <a-entity position="-8 0 -6">
      <a-cylinder radius="0.15" height="1.5" color="#5C3317"></a-cylinder>
      <a-sphere radius="1.0" color="#33691E" position="0 2.2 0"></a-sphere>
    </a-entity>


    <!-- ════════════════════════════════
         BIRDS  (V-shape box pairs)
    ════════════════════════════════ -->
    <a-box position="2.8 7.2 -13" width="0.32" height="0.045" depth="0.045" color="#222" rotation="0 0  24"></a-box>
    <a-box position="3.2 7.3 -13" width="0.32" height="0.045" depth="0.045" color="#222" rotation="0 0 -24"></a-box>
    <a-box position="5.2 7.8 -15" width="0.30" height="0.040" depth="0.040" color="#222" rotation="0 0  24"></a-box>
    <a-box position="5.6 7.9 -15" width="0.30" height="0.040" depth="0.040" color="#222" rotation="0 0 -24"></a-box>
    <a-box position="0.5 8.2 -16" width="0.26" height="0.038" depth="0.038" color="#222" rotation="0 0  24"></a-box>
    <a-box position="0.8 8.3 -16" width="0.26" height="0.038" depth="0.038" color="#222" rotation="0 0 -24"></a-box>


    <!-- ════════════════════════════════
         LIGHTING
         Multiple lights so table items
         are clearly illuminated
    ════════════════════════════════ -->
    <!-- Global ambient -->
    <a-light type="ambient"     color="#ffffff"  intensity="0.80"></a-light>
    <!-- Sunlight from upper-right -->
    <a-light type="directional" color="#FFF5CC"  intensity="1.10" position="8 14 -2"></a-light>
    <!-- Warm fill above scene centre -->
    <a-light type="point"       color="#FFE680"  intensity="0.70" position="0 5 -1"></a-light>
    <!-- Dedicated table spotlight (directly above table) -->
    <a-light type="point"       color="#ffffff"  intensity="0.90" position="0 2.8 -3"></a-light>
    <!-- Close fill on table items from front -->
    <a-light type="point"       color="#ffffff"  intensity="0.60" position="0 1.8 -1.5"></a-light>


    <!-- ════════════════════════════════
         CAMERA & CURSOR
    ════════════════════════════════ -->
    <a-camera position="0 1.65 3.5" look-controls wasd-controls>
      <a-cursor color="#ffffff" opacity="0.8"></a-cursor>
    </a-camera>

  </a-scene>

</body>
</html>